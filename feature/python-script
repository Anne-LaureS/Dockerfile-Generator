#!/usr/bin/env python3
# Script : generate_dockerfile.py
# Description : Génère un Dockerfile et un app.py minimal à partir d'une image Docker choisie

import argparse
import os

print("=== Dockerfile Generator (Python) ===")

def generate_dockerfile(image):
    dockerfile_content = f"""FROM {image}

WORKDIR /app
COPY app.py .

CMD ["python", "app.py"]
"""
    with open("Dockerfile", "w") as f:
        f.write(dockerfile_content)

    print("[+] Dockerfile généré avec succès.")


def generate_app_py(app_name):
    app_content = f"""print("Hello from {app_name}!")"""

    with open("app.py", "w") as f:
        f.write(app_content)

    print("[+] app.py généré avec succès.")


def main():
    parser = argparse.ArgumentParser(description="Générateur automatique de Dockerfile et app.py")
    parser.add_argument("--image", required=True, help="Nom de l'image Docker (ex: python:3.11-slim)")
    parser.add_argument("--app-name", required=True, help="Nom de l'application")

    args = parser.parse_args()

    generate_dockerfile(args.image)
    generate_app_py(args.app_name)

    print("\n🎉 Génération terminée !")


if __name__ == "__main__":
    main()
